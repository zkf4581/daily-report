# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored and must never be committed.

# ---- Supabase (public, safe to ship to the browser) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---- Supabase service_role (SERVER-ONLY) ----
# ⚠️ NEVER prefix this with NEXT_PUBLIC_. The service_role key bypasses all
# Row Level Security and grants full admin access to the database.
# Import it only from Route Handlers / Server Actions via lib/supabase/admin.ts.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Email reminders (P6) ----
# Resend API key — used by the `send-reminders` Edge Function.
RESEND_API_KEY=
# Verified sender address in Resend, used as the From: header.
REMINDER_FROM_EMAIL=
# Shared secret between pg_cron / pg_net and the send-reminders Edge Function.
# The function rejects requests whose Authorization header does not match.
REMINDER_AUTH_TOKEN=

